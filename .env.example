API_KEY=your-openrouter-api-key
# Use a free model to avoid credit costs, e.g.:
#   deepseek/deepseek-chat-v3:free
#   meta-llama/llama-3.3-70b-instruct:free
MODEL=deepseek/deepseek-chat-v3:free
# Web search for study resources needs OpenRouter credits (paid). Leave false when
# using free models. You can also toggle this each run when prompted.
ENABLE_WEB_SEARCH=false
