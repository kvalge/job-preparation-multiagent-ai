API_KEY=your-openrouter-api-key
MODEL=deepseek/deepseek-chat-v3:free
# Optional second model used automatically when the primary model fails after a
# retry (empty/malformed responses, rate limits, etc.). Leave blank to disable.
# Pick a different free model than MODEL, e.g.:
#   FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
FALLBACK_MODEL=chooseyourfallbackmodel
# Web search for study resources needs OpenRouter credits (paid). Leave false when
# using free models. You can also toggle this each run when prompted.
ENABLE_WEB_SEARCH=false
